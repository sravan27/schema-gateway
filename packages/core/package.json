{
  "name": "@apex-value/schema-gateway-core",
  "version": "0.1.0",
  "description": "Core schema normalization, repair, and signing helpers for Schema Gateway.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://schema-gateway.sridharsravan.workers.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sravan27/schema-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/sravan27/schema-gateway/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "schema",
    "json-schema",
    "llm",
    "tool-calling",
    "structured-output",
    "openai",
    "gemini",
    "anthropic",
    "ollama",
    "schema-portability",
    "schema-validation",
    "function-calling"
  ],
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "jsonrepair": "3.13.3",
    "viem": "2.47.10",
    "zod": "4.3.6"
  }
}
