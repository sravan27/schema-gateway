{
  "name": "@apex-value/schema-gateway",
  "version": "0.1.0",
  "description": "Free local validator and paid API client for provider-agnostic structured output normalization.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://schema-gateway.sridharsravan.workers.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sravan27/schema-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/sravan27/schema-gateway/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "schema-gateway": "./dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "schema",
    "json-schema",
    "llm",
    "structured-output",
    "cli",
    "openai",
    "gemini",
    "anthropic",
    "ollama",
    "tool-calling",
    "response-format",
    "schema-validation",
    "ai-agents"
  ],
  "dependencies": {
    "@apex-value/schema-gateway-core": "0.1.0"
  }
}
